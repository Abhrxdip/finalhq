  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000"
    },
    {
      "key": "wallet",
      "value": "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAY5HFKQ"
    },
    {
      "key": "ipfsHash",
      "value": "bafkreigh2akiscaildc4u5n2v6clvvmh6jyl7f7xoe4w4f4k6slprj6gny"
    },
    {
      "key": "appId",
      "value": "123456"
    },
    {
