ALGORAND_MNEMONIC=
ALGO_ADMIN_MNEMONIC=
DEPLOYER_MNEMONIC=
ALGO_XP_APP_ID=
ALGO_STRICT=false
ALGO_SIMULATE_ON_ERROR=true

# Python bridge settings (blockchain/scripts)
PYTHON_BIN=python
ALGO_SCRIPTS_DIR=
PYTHON_TIMEOUT_MS=60000
