PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hackquest
PGSSL=false
CORS_ORIGIN=*

# Authentication
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=7d
JWT_ISSUER=hackquest-backend
PASSWORD_SALT_ROUNDS=10
